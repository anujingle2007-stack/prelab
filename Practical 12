<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Updated Bootstrap Layout</title>
    <style>
      /* Keep carousel height manageable */
      .carousel-item img {
        height: 500px;
        object-fit: cover;
      }
      .section-padding { padding: 60px 0; }
    </style>
  </head>
  <body>

    <!-- Navbar with Dark Theme -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
      <div class="container">
        <a class="navbar-brand fw-bold" href="#">MY BRAND</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Services</a></li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="navDrop" data-bs-toggle="dropdown">Explore</a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#">Action</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="#">Special Deals</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Carousel -->
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
      <div class="carousel-inner shadow-sm">
        <div class="carousel-item active">
          <img src="https://placeholder.com" class="d-block w-100" alt="Slide 1">
        </div>
        <div class="carousel-item">
          <img src="https://placeholder.com" class="d-block w-100" alt="Slide 2">
        </div>
      </div>
      <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
      </button>
    </div>

    <!-- Main Content -->
    <div class="container section-padding">
      <div class="row g-4">
        <!-- Card 1 -->
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <img src="https://placeholder.com" class="card-img-top" alt="...">
            <div class="card-body">
              <h5 class="card-title">Featured Project</h5>
              <p class="card-text">High-quality components used to build modern responsive web interfaces.</p>
              <a href="#" class="btn btn-primary w-100">View More</a>
            </div>
          </div>
        </div>

        <!-- Buttons Section (Re-styled as a list/group) -->
        <div class="col-md-8">
          <div class="p-4 border rounded bg-light">
            <h3>Action Center</h3>
            <p class="text-muted">Choose an action to perform below:</p>
            <div class="d-flex flex-wrap gap-2">
              <button class="btn btn-success rounded-pill">Success</button>
              <button class="btn btn-danger rounded-pill">Danger</button>
              <button class="btn btn-warning rounded-pill text-white">Warning</button>
              <button class="btn btn-info rounded-pill text-white">Info</button>
              <button class="btn btn-outline-dark rounded-pill">Outline Dark</button>
            </div>
          </div>

          <!-- Grid Columns -->
          <div class="row mt-4">
            <div class="col-sm-6"><div class="p-3 bg-primary text-white text-center rounded mb-2">Column A</div></div>
            <div class="col-sm-6"><div class="p-3 bg-secondary text-white text-center rounded mb-2">Column B</div></div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"></script>
  </body>
</html>
 
