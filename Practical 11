<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>The Mood Board</title>
    <style>
        :root {
            --primary: #6366f1;
            --bg: #f8fafc;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px;
        }
        .container {
            background: white;
            padding: 30px;
            border-radius: 24px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }
        h1 { font-size: 1.5rem; color: #1e293b; margin-bottom: 5px; }
        #location-status { font-size: 0.85rem; color: #64748b; margin-bottom: 25px; }
        
        /* Drag Items */
        .vibe-list {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 30px;
        }
        .mood-item {
            padding: 12px 18px;
            background: #fff;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            cursor: grab;
            transition: all 0.2s;
            font-weight: 500;
        }
        .mood-item:hover { border-color: var(--primary); transform: translateY(-2px); }

        /* Drop Zone */
        .stage {
            height: 120px;
            border: 2px dashed #cbd5e1;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            margin-bottom: 25px;
            transition: background 0.3s;
        }
        .stage.over { background: #e0e7ff; border-color: var(--primary); }

        /* Buttons */
        .action-btns { display: flex; gap: 10px; }
        button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 10px;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.2s;
        }
        .btn-loc { background: var(--primary); color: white; }
        .btn-reset { background: #fee2e2; color: #ef4444; }
    </style>
</head>
<body>

    <div class="container">
        <h1>Mood Check-in</h1>
        <p id="location-status">📍 Position Unknown</p>

        <div class="stage" id="drop-area">
            <span style="color: #94a3b8;">Place your vibe here</span>
        </div>

        <div class="vibe-list" id="mood-bank">
            <div class="mood-item" draggable="true" id="m1">🔥 On Fire</div>
            <div class="mood-item" draggable="true" id="m2">🌊 Chilled</div>
            <div class="mood-item" draggable="true" id="m3">✨ Inspired</div>
        </div>

        <div class="action-btns">
            <button class="btn-loc" onclick="findMe()">Stamp Location</button>
            <button class="btn-reset" onclick="clearAll()">Reset</button>
        </div>
    </div>

    <script>
        const dropArea = document.getElementById('drop-area');
        const moodBank = document.getElementById('mood-bank');

        // Drag & Drop Logic
        document.addEventListener('dragstart', e => {
            if(e.target.classList.contains('mood-item')) {
                e.dataTransfer.setData('text/plain', e.target.id);
            }
        });

        dropArea.addEventListener('dragover', e => {
            e.preventDefault();
            dropArea.classList.add('over');
        });

        dropArea.addEventListener('dragleave', () => dropArea.classList.remove('over'));

        dropArea.addEventListener('drop', e => {
            e.preventDefault();
            dropArea.classList.remove('over');
            const moodId = e.dataTransfer.getData('text/plain');
            applyMood(moodId);
        });

        function applyMood(id) {
            const el = document.getElementById(id);
            if (el) {
                dropArea.innerHTML = '';
                dropArea.appendChild(el);
                localStorage.setItem('activeMood', id);
            }
        }

        // Geolocation
        function findMe() {
            navigator.geolocation.getCurrentPosition(p => {
                const text = `Coords: ${p.coords.latitude.toFixed(2)}, ${p.coords.longitude.toFixed(2)}`;
                document.getElementById('location-status').innerText = "📍 " + text;
                localStorage.setItem('userLoc', text);
            });
        }

        // Reset
        function clearAll() {
            localStorage.clear();
            location.reload(); 
        }

        // Persistence
        window.onload = () => {
            const savedMood = localStorage.getItem('activeMood');
            if (savedMood) applyMood(savedMood);
            
            const savedLoc = localStorage.getItem('userLoc');
            if (savedLoc) document.getElementById('location-status').innerText = "📍 " + savedLoc;
        };
    </script>
</body>
</html>
