<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>MahaDBT Scholarship Portal</title>
    <style>
        /* Modern styling to improve the layout */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f9;
            display: flex;
            justify-content: center;
            padding: 40px 20px;
            margin: 0;
        }

        .form-container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            max-width: 600px;
            width: 100%;
        }

        h2 {
            color: #2c3e50;
            text-align: center;
            border-bottom: 2px solid #3498db;
            padding-bottom: 10px;
            margin-top: 0;
        }

        h3 {
            color: #34495e;
            font-size: 1.1rem;
            margin: 25px 0 15px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #555;
        }

        input[type="text"],
        input[type="email"],
        input[type="number"],
        select,
        textarea {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border: 1px solid #ddd;
            border-radius: 6px;
            box-sizing: border-box; /* Ensures padding doesn't affect width */
            font-size: 14px;
        }

        .radio-group {
            margin-bottom: 15px;
            padding: 10px;
            background: #f9f9f9;
            border-radius: 6px;
        }

        .btn-group {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            transition: opacity 0.2s;
        }

        button[type="submit"] {
            background-color: #27ae60;
            color: white;
        }

        button[type="reset"] {
            background-color: #e74c3c;
            color: white;
        }

        button:hover {
            opacity: 0.9;
        }

        svg {
            vertical-align: middle;
            margin-right: 5px;
        }
    </style>
</head>
<body>

<div class="form-container">
    <h2>MahaDBT Scholarship Application</h2>

    <form>
        <!-- Personal Info Section -->
        <h3>Personal Information</h3>
        
        <label>User ID:</label>
        <input type="text" name="Username" placeholder="Enter your ID">
        
        <div style="display: flex; gap: 10px;">
            <div style="flex: 1;">
                <label>First Name:</label>
                <input type="text" name="firstname" placeholder="First Name">
            </div>
            <div style="flex: 1;">
                <label>Last Name:</label>
                <input type="text" name="lastname" placeholder="Last Name" required>
            </div>
        </div>

        <label>Middle Name:</label>
        <input type="text" name="middlename" placeholder="Enter Middle Name" required>

        <label>Email Address:</label>
        <input type="email" name="email" placeholder="example@mail.com" required>

        <label>Mobile Number:</label>
        <input type="number" name="mobile" placeholder="10-digit number" required>

        <!-- Aadhaar Section -->
        <h3>Aadhaar Details</h3>
        <label>Do you have Aadhaar Card?</label>
        <div class="radio-group">
            <input type="radio" name="aadhaar" value="yes"> Yes &nbsp;&nbsp;
            <input type="radio" name="aadhaar" value="no"> No
        </div>

        <label>Aadhaar Number:</label>
        <input type="text" name="aadhaarNumber" placeholder="12-digit Aadhaar Number">

        <!-- Address Section -->
        <h3>Address Information</h3>
        <label>Permanent Address:</label>
        <textarea name="address" rows="3" placeholder="Flat No, Street, Landmark..."></textarea>

        <label>District:</label>
        <input type="text" name="district" placeholder="Enter District">

        <!-- Category Section -->
        <h3>Educational & Category Details</h3>
        <label>Caste Category:</label>
        <select name="category" required>
            <option value="">-- Select Category --</option>
            <option value="SC">SC</option>
            <option value="ST">ST</option>
            <option value="OBC">OBC</option>
            <option value="OPEN">OPEN / EBC</option>
        </select>

        <label>Annual Family Income (₹):</label>
        <input type="number" name="income" placeholder="Enter Amount">

        <div class="btn-group">
            <button type="submit">Submit Application</button>
            <button type="reset">Clear Form</button>
        </div>
    </form>
</div>

</body>
</html>
